{
  "name": "freecourse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true});console.log('[prebuild] Cleaned .next/')}catch(e){console.log('[prebuild] No .next/ to clean')}\"",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone.js",
    "start": "node start.js",
    "lint": "eslint",
    "test:areas": "node --experimental-strip-types scripts/check-regions.mjs && node --experimental-strip-types scripts/check-age-validation.mjs && node --experimental-strip-types scripts/check-dashboard-areas.mjs"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-draggable": "^4.5.0",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5"
  }
}
